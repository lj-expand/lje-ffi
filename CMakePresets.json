{
  "version": 3,
  "configurePresets": [
    {
      "name": "x64-windows-rel",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "x64-windows-dbg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-windows-rel",
      "configurePreset": "x64-windows-rel"
    },
    {
      "name": "x64-windows-dbg",
      "configurePreset": "x64-windows-dbg"
    }
  ]
}
